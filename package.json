{
  "name": "exiled-orb",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "ExiledOrb — all-in-one Path of Exile companion (desktop overlay)",
  "scripts": {
    "dev:overlay": "turbo run dev --filter=@exiled-orb/overlay",
