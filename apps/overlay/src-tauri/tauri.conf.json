{
  "$schema": "https://raw.githubusercontent.com/nicknisi/dotfiles/refs/heads/main/.config/tauri/tauri.conf.schema.json",
  "productName": "ExiledOrb",
  "version": "0.1.0",
  "identifier": "com.exiled-orb.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "ExiledOrb",
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": true,
        "width": 420,
        "height": 800,
        "x": 20,
        "y": 20
      },
      {
        "label": "settings",
        "title": "ExiledOrb Settings",
        "visible": false,
        "width": 900,
        "height": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {
      "preload": ["sqlite:exiled-orb.db"]
    }
  }
}
