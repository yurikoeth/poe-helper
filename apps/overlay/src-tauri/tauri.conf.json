{
  "$schema": "https://raw.githubusercontent.com/nicknisi/dotfiles/refs/heads/main/.config/tauri/tauri.conf.schema.json",
  "productName": "PoE Helper",
  "version": "0.1.0",
  "identifier": "com.poe-helper.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "PoE Helper",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "width": 420,
        "height": 650,
        "x": 20,
        "y": 20
      },
      {
        "label": "settings",
        "title": "PoE Helper Settings",
        "visible": false,
        "width": 900,
        "height": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "clipboard-manager": {
      "all": true
    },
    "shell": {
      "open": true
    }
  }
}
