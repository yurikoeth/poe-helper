{
  "name": "@exiled-orb/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "development": "./src/types/index.ts",
      "import": "./dist/types/index.js"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "development": "./src/parsers/index.ts",
      "import": "./dist/parsers/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "development": "./src/api/index.ts",
      "import": "./dist/api/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "development": "./src/data/index.ts",
      "import": "./dist/data/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^3.2.0"
  }
}
